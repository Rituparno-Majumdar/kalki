# Kalki environment variables
# Copy this file to .env and fill in values for local development
# Never commit .env to version control

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kalki
POSTGRES_USER=kalki
POSTGRES_PASSWORD=kalki_dev

# Full connection URL (used by SQLAlchemy and psycopg2)
DATABASE_URL=postgresql://kalki:kalki_dev@localhost:5432/kalki

# --- DuckDB ---
# Path to the local DuckDB file (created automatically on first run)
DUCKDB_PATH=./data/kalki_analytics.duckdb

# --- Data Lake ---
# Local path where raw connector output is stored before DB ingestion
DATA_LAKE_PATH=./data/lake

# --- Logging ---
LOG_LEVEL=INFO
